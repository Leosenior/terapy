<!doctype html>
<html lang="it">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>Terapia Cloud - tracker locale & sync</title>
  <!-- Firebase SDK -->
  <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-database-compat.js"></script>
  <style>
    :root{
      --bg:#eef4ff;
      --bg2:#ffffff;
      --ink:#14213d;
      --muted:#6d7a98;
      --line:#d8e1f0;
      --soft:#edf3ff;
      --navy:#203a8f;
      --navy2:#3e63dd;
      --teal:#0ea5a8;
      --green:#16a34a;
      --red:#ef4444;
      --shadow:0 12px 30px rgba(31,55,110,.12);
      --shadow2:0 6px 16px rgba(31,55,110,.08);
    }
    *{box-sizing:border-box}
    html,body{margin:0;background:linear-gradient(180deg,#eef4ff 0%,#f7f9ff 28%,#ffffff 100%);color:var(--ink);font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif}
    body{min-height:100vh}
    button,input,select,textarea{font:inherit}
    button{cursor:pointer;border:0;background:transparent;color:inherit}
    .app{max-width:560px;margin:0 auto;padding:18px 12px 32px}
    .shell{background:rgba(255,255,255,.82);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,.7);border-radius:30px;box-shadow:var(--shadow);padding:14px}
    .top{display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:14px;padding:6px 4px 0}
    h1{font-size:34px;line-height:1;margin:0 0 8px;font-weight:950;letter-spacing:-.05em}
    .sub{color:var(--muted);font-weight:800;font-size:16px}
    .tabs{display:flex;gap:4px;padding:4px;border-radius:18px;background:linear-gradient(180deg,#f9fbff,#edf2ff);border:1px solid var(--line);box-shadow:var(--shadow2);overflow-x:auto}
    .tab{padding:10px 14px;border-radius:14px;color:var(--muted);font-weight:900;font-size:14px;white-space:nowrap;transition:.18s ease}
    .tab.active{background:linear-gradient(135deg,var(--navy),var(--navy2));color:white;box-shadow:0 8px 16px rgba(62,99,221,.28)}
    .summary{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin:8px 0 16px}
    .sumcard{background:linear-gradient(180deg,#ffffff,#f3f7ff);border:1px solid var(--line);border-radius:20px;padding:14px 14px 13px;box-shadow:var(--shadow2)}
    .sumlabel{font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);font-weight:900;margin-bottom:6px}
    .sumvalue{font-size:24px;font-weight:950;letter-spacing:-.05em;line-height:1.05}
    .sumsub{margin-top:5px;color:var(--muted);font-size:13px;font-weight:800}
    .weeknav{display:grid;grid-template-columns:50px 1fr 50px;align-items:center;gap:10px;margin-bottom:14px}
    .square{height:46px;border:1px solid var(--line);border-radius:15px;display:flex;align-items:center;justify-content:center;font-size:26px;font-weight:900;background:linear-gradient(180deg,#fff,#f2f6ff);box-shadow:var(--shadow2);transition:.18s ease}
    .range{text-align:center;font-size:20px;font-weight:950;letter-spacing:-.03em}
    .range small{font-size:16px;color:var(--navy2);font-weight:900;margin-left:5px}
    .days{display:grid;grid-template-columns:repeat(7,1fr);gap:7px;margin-bottom:20px}
    .daychip{height:72px;border:1px solid var(--line);border-radius:18px;display:flex;flex-direction:column;align-items:center;justify-content:center;background:linear-gradient(180deg,#fff,#f5f8ff);color:#57627c;font-weight:900;box-shadow:var(--shadow2);transition:.18s ease}
    .daychip .dn{font-size:13px;margin-bottom:3px}
    .daychip .dd{font-size:24px;line-height:1;color:var(--ink);letter-spacing:-.05em}
    .daychip.active{background:linear-gradient(135deg,var(--navy),var(--navy2));border-color:transparent;color:#d9e4ff;transform:translateY(-1px);box-shadow:0 12px 22px rgba(62,99,221,.28)}
    .daychip.active .dd{color:white}
    .daychip.today:not(.active){border-color:#a6c0ff;background:linear-gradient(180deg,#ffffff,#eef4ff)}
    .daytitle{display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:14px;padding:2px 2px 0}
    .daytitle h2{font-size:28px;line-height:1.05;margin:0;font-weight:950;letter-spacing:-.05em}
    .daytitle h2 span{display:block;color:var(--muted);font-size:20px;font-weight:850;letter-spacing:-.02em;margin-top:3px}
    .cycle{color:var(--navy2);font-weight:900;font-size:15px;white-space:nowrap;background:#edf3ff;border:1px solid #d7e3ff;border-radius:14px;padding:8px 11px}
    .weekstats{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:18px}
    .miniStat{border-radius:18px;padding:12px 13px;background:linear-gradient(180deg,#fff,#f6f9ff);border:1px solid var(--line);box-shadow:var(--shadow2)}
    .miniStat .k{font-size:12px;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);font-weight:900}
    .miniStat .v{font-size:20px;font-weight:950;letter-spacing:-.04em;margin-top:4px}
    .progress{height:9px;border-radius:999px;background:#e7eefb;overflow:hidden;margin-top:10px}
    .progress > span{display:block;height:100%;border-radius:999px;background:linear-gradient(90deg,var(--teal),var(--navy2))}
    .section{margin:0 0 24px}
    .section h3{font-size:15px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);font-weight:950;margin:0 0 11px;padding-left:2px}
    .empty{border:1px dashed var(--line);border-radius:18px;padding:18px;color:var(--muted);font-weight:800;background:var(--soft)}
    .card{display:flex;align-items:center;gap:14px;min-height:78px;border:1.3px solid var(--line);border-radius:22px;background:linear-gradient(180deg,#ffffff,#f9fbff);padding:15px 16px;margin:0 0 10px;box-shadow:var(--shadow2);transition:.18s ease}
    .card.taken{background:linear-gradient(180deg,#f1fbf4,#ecf9f0);border-color:#b6e3c5}
    .card.taken .name,.card.taken .dose{text-decoration:line-through;text-decoration-thickness:2px;text-decoration-color:#59996f;color:#557162}
    .card.taken .note{color:#64806f}
    .check{width:34px;height:34px;border-radius:12px;border:2px solid var(--line);display:flex;align-items:center;justify-content:center;flex:0 0 auto;background:#fff;color:white;font-size:20px;font-weight:900;transition:.18s ease}
    .taken .check{background:linear-gradient(135deg,var(--green),#22c55e);border-color:transparent;box-shadow:0 8px 14px rgba(34,197,94,.25)}
    .txt{min-width:0;flex:1}
    .line1{display:flex;flex-wrap:wrap;gap:8px;align-items:baseline;font-size:21px;line-height:1.1;font-weight:950;letter-spacing:-.04em}
    .dose{color:var(--navy2);font-weight:850}
    .note{margin-top:7px;color:var(--muted);font-size:14px;font-weight:850;line-height:1.25}
    .warn{background:linear-gradient(180deg,#fff7e8,#fff2cc);border:1px solid #f4dd97;color:#765300;border-radius:18px;padding:14px 15px;font-weight:800;line-height:1.35;margin:0 0 16px;font-size:14px}
    .panel{display:none}
    .panel.active{display:block}
    .formtop{display:grid;gap:12px;margin-bottom:18px}
    .field{display:grid;gap:7px}
    label{font-weight:850;color:var(--muted);font-size:13px;letter-spacing:.02em}
    input,select,textarea{width:100%;border:1px solid var(--line);border-radius:15px;padding:11px 12px;background:#fff;color:var(--ink);font-weight:750;outline:none;box-shadow:inset 0 1px 2px rgba(0,0,0,.02)}
    input:focus,select:focus,textarea:focus{border-color:#95b4ff;box-shadow:0 0 0 4px rgba(62,99,221,.12)}
    textarea{min-height:120px;resize:vertical;font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-size:12px;font-weight:600}
    .toolbar{display:flex;flex-wrap:wrap;gap:8px;margin:14px 0 20px}
    .pillbtn{border:1px solid var(--line);border-radius:14px;padding:10px 12px;font-weight:850;background:linear-gradient(180deg,#fff,#f7faff);color:var(--ink);box-shadow:var(--shadow2)}
    .pillbtn.dark{background:linear-gradient(135deg,var(--navy),var(--navy2));color:#fff;border-color:transparent}
    .pillbtn.red{background:linear-gradient(135deg,var(--red),#ef4444);color:#fff;border-color:transparent}
    .mededit{border:1px solid var(--line);border-radius:22px;padding:14px;margin-bottom:12px;background:linear-gradient(180deg,#fff,#f8faff);box-shadow:var(--shadow2)}
    .medhead{display:flex;align-items:center;gap:10px;margin-bottom:12px}
    .handle{font-size:18px;color:var(--muted);font-weight:900;cursor:grab;user-select:none}
    .medtitle{font-weight:950;letter-spacing:-.03em;flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .mini{font-size:12px;border:1px solid var(--line);border-radius:10px;padding:7px 9px;font-weight:900;background:#fff;color:var(--muted)}
    .grid2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
    .daysedit{display:grid;grid-template-columns:repeat(7,1fr);gap:5px;margin-top:6px}
    .daycheck{border:1px solid var(--line);border-radius:10px;text-align:center;padding:8px 0;font-size:12px;font-weight:900;color:var(--muted);user-select:none;background:#fff}
    .daycheck.on{background:linear-gradient(135deg,var(--navy),var(--navy2));border-color:transparent;color:#fff;box-shadow:0 8px 14px rgba(62,99,221,.18)}
    .hide{display:none!important}
    
    /* Cloud Sync Status */
    .sync-status {
      display: flex; align-items: center; gap: 6px; font-size: 12px; font-weight: 850;
      padding: 6px 10px; border-radius: 10px; background: var(--soft); margin-top: 8px;
    }
    .sync-status.online { color: var(--green); }
    .sync-status.offline { color: var(--red); }
    .dot { width: 8px; height: 8px; border-radius: 50%; background: currentColor; }

    /* Modal Stili */
    .modal {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(0,0,0,0.4); backdrop-filter: blur(4px);
      display: none; align-items: center; justify-content: center; z-index: 1000;
      padding: 20px;
    }
    .modal.active { display: flex; }
    .modal-content {
      background: #fff; border-radius: 24px; padding: 24px;
      max-width: 500px; width: 100%; box-shadow: var(--shadow);
      max-height: 90vh; overflow-y: auto;
    }
    .modal-content h2 { margin: 0 0 20px; font-size: 24px; font-weight: 900; letter-spacing: -0.04em; }
    .modal-footer { display: flex; gap: 10px; margin-top: 24px; }
    .modal-footer button { flex: 1; padding: 12px; border-radius: 14px; font-weight: 850; }
    .btn-cancel { background: var(--soft); color: var(--muted); }
    .btn-confirm { background: var(--navy); color: #fff; }
    .form-grid { display: grid; gap: 15px; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .slot-checks { display: flex; gap: 10px; margin-top: 5px; }
    .slot-check { flex: 1; border: 1px solid var(--line); border-radius: 10px; padding: 8px; font-size: 12px; font-weight: 850; text-align: center; }
    .slot-check.on { background: var(--navy2); color: #fff; border-color: transparent; }

    .modal-list { display: grid; gap: 8px; margin-top: 10px; }
    .modal-list-item {
      display: flex; justify-content: space-between; align-items: center;
      padding: 12px 16px; border: 1px solid var(--line); border-radius: 15px;
      background: var(--soft); font-weight: 850;
    }
    .modal-list-item button { color: var(--red); font-weight: 950; font-size: 12px; border: 1px solid var(--red); border-radius: 8px; padding: 4px 8px; background: #fff; }

    .history-item {
      padding: 12px; border-bottom: 1px solid var(--line);
      display: flex; justify-content: space-between; align-items: center;
    }
    .history-item:last-child { border: 0; }
    .history-date { font-weight: 900; font-size: 14px; color: var(--navy); }
    .history-details { font-size: 13px; color: var(--muted); font-weight: 750; }

    @media (max-width:420px){
      .app{padding:16px 12px 28px}
      .shell{padding:12px;border-radius:28px}
      h1{font-size:31px}
      .tabs{padding:4px}.tab{padding:8px 12px;font-size:14px}
      .summary,.weekstats{grid-template-columns:1fr 1fr;gap:8px}
      .sumcard,.miniStat{padding:12px}
      .days{gap:5px}.daychip{height:66px;border-radius:15px}.daychip .dd{font-size:22px}
      .card{border-radius:19px;padding:13px 14px}.line1{font-size:19px}
      .grid2{grid-template-columns:1fr}
      .cycle{font-size:14px;padding:7px 10px}
    }
  </style>
</head>
<body>
  <main class="app">
    <div class="shell">
      <section class="top">
        <div>
          <h1>Terapia Cloud</h1>
          <div class="sub" id="startText"></div>
          <div id="syncStatus" class="sync-status offline"><div class="dot"></div><span>Cloud Disconnesso</span></div>
        </div>
        <div class="tabs" role="tablist">
          <button class="tab active" id="tabWeek">Settimana</button>
          <button class="tab" id="tabMeds">Farmaci</button>
          <button class="tab" id="tabHistory">Storico</button>
        </div>
      </section>

      <section id="weekPanel" class="panel active">
        <div class="summary">
          <div class="sumcard">
            <div class="sumlabel">Prese oggi</div>
            <div class="sumvalue" id="takenToday">0 / 0</div>
            <div class="sumsub" id="takenTodaySub">-</div>
          </div>
          <div class="sumcard">
            <div class="sumlabel">Totale settimana</div>
            <div class="sumvalue" id="takenWeek">0 / 0</div>
            <div class="sumsub" id="takenWeekSub">-</div>
          </div>
        </div>
        <div class="weeknav">
          <button class="square" id="prevWeek">←</button>
          <div class="range" id="weekRange"></div>
          <button class="square" id="nextWeek">→</button>
        </div>
        <div class="days" id="days"></div>
        <div class="daytitle">
          <h2 id="dayTitle"></h2>
          <div class="cycle" id="cycleText"></div>
        </div>
        <div class="weekstats">
          <div class="miniStat">
            <div class="k">Da prendere oggi</div>
            <div class="v" id="dueToday">0 voci</div>
            <div class="progress"><span id="progressToday" style="width:0%"></span></div>
          </div>
          <div class="miniStat">
            <div class="k">Completamento settimana</div>
            <div class="v" id="weekPercent">0%</div>
            <div class="progress"><span id="progressWeek" style="width:0%"></span></div>
          </div>
        </div>
        <div id="sections"></div>
      </section>

      <section id="medsPanel" class="panel">
        <div class="warn">Configura Firebase per attivare la sincronizzazione multi-dispositivo.</div>
        <div class="formtop">
          <div class="grid2">
            <div class="field">
              <label>Data inizio ciclo globale</label>
              <input type="date" id="startDate" />
            </div>
            <div class="field">
              <label>Durata ciclo globale</label>
              <div style="display:flex; gap:8px;">
                <input type="number" id="cycleDuration" value="30" style="flex:1" />
                <select id="cycleUnit" style="flex:1">
                  <option value="days">Giorni</option>
                  <option value="weeks">Settimane</option>
                </select>
              </div>
            </div>
          </div>
        </div>
        <div class="toolbar">
          <button class="pillbtn dark" id="addMedBtn">+ Aggiungi farmaco</button>
          <button class="pillbtn red" id="removeMedBtn">Rimuovi farmaco</button>
          <button class="pillbtn" id="exportBtn">Export JSON</button>
          <button class="pillbtn" id="importBtn">Import JSON</button>
          <button class="pillbtn" id="resetBtn">Reset template</button>
        </div>
        <div class="field hide" id="jsonBoxWrap">
          <label>JSON backup / import</label>
          <textarea id="jsonBox" spellcheck="false"></textarea>
        </div>
        <div id="medEditor"></div>
      </section>

      <section id="historyPanel" class="panel">
        <div class="warn">Database storico delle somministrazioni sincronizzate nel cloud.</div>
        <div id="historyList" class="shell" style="padding:0; overflow:hidden; border-radius:20px;"></div>
      </section>
    </div>
  </main>

  <!-- Modali (Nuovo, Rimozione) -->
  <div id="medModal" class="modal"><div class="modal-content"><h2>Nuovo Farmaco</h2><div class="form-grid"><div class="field"><label>Nome farmaco</label><input type="text" id="mName" placeholder="es. Creatina"></div><div class="form-row"><div class="field"><label>Data Inizio</label><input type="date" id="mStartDate"></div><div class="field"><label>Data Fine (opzionale)</label><input type="date" id="mEndDate"></div></div><div class="form-row"><div class="field"><label>Dose Totale Iniziale (es. 1g)</label><input type="text" id="mDoseInit" placeholder="1g"></div><div class="field"><label>Operazione Rampa</label><select id="mOp"><option value="none">Nessuna (dose fissa)</option><option value="add">Aumenta (+)</option><option value="sub">Sottrai (-)</option></select></div></div><div id="rampFields" style="display:none; gap:15px; flex-direction:column;"><div class="form-row"><div class="field"><label>Variazione Totale (es. 20mcg)</label><input type="text" id="mStep" placeholder="20mcg"></div><div class="field"><label>Limite Totale (stop)</label><input type="text" id="mLimit" placeholder="es. 100mcg"></div></div><div class="field"><label>Frequenza variazione</label><div style="display:flex; align-items:center; gap:8px;">Ogni <input type="number" id="mFreq" value="1" style="width:60px"> giorni</div></div></div><div class="form-row"><div class="field"><label>Durata (se Data Fine vuota)</label><input type="number" id="mDur" value="30"></div><div class="field"><label>Unità</label><select id="mUnit"><option value="days">Giorni</option><option value="weeks">Settimane</option><option value="months">Mesi</option></select></div></div><div class="field"><label>Giorni della settimana</label><div class="daysedit" id="mDays"></div></div><div class="field"><label>Suddivisione giornata (dose totale divisa tra questi)</label><div class="slot-checks"><button class="slot-check on" data-slot="mattina">Mattina</button><button class="slot-check" data-slot="pomeriggio">Pomeriggio</button><button class="slot-check" data-slot="sera">Sera</button></div></div></div><div class="modal-footer"><button class="btn-cancel" onclick="closeModal()">Annulla</button><button class="btn-confirm" onclick="confirmMed()">Conferma</button></div></div></div>
  <div id="removeModal" class="modal"><div class="modal-content"><h2>Rimuovi Farmaco</h2><p style="font-size:13px; color:var(--muted); font-weight:750; margin-bottom:15px;">Seleziona un farmaco per eliminare tutte le sue voci dal cloud.</p><div id="removeList" class="modal-list"></div><div class="modal-footer"><button class="btn-cancel" onclick="closeRemoveModal()">Chiudi</button></div></div></div>

<script>
/**
 * CONFIGURAZIONE FIREBASE
 * Incolla qui i tuoi dati da Firebase Console -> Project Settings -> General -> Web App
 */
const firebaseConfig = { 
  apiKey: "AIzaSyCtr9H1cuSuMksU8u7OYu1pVvChP04U3G0", 
  authDomain: "terapy-fd8f8.firebaseapp.com", 
  databaseURL: "https://terapy-fd8f8-default-rtdb.europe-west1.firebasedatabase.app", 
  projectId: "terapy-fd8f8", 
  storageBucket: "terapy-fd8f8.firebasestorage.app", 
  messagingSenderId: "231660888187", 
  appId: "1:231660888187:web:d5157b552216248e4882de" 
};

(function(){
  const STORE_LOCAL = 'therapy-tracker-backup';
  const dayNames=['Lunedì','Martedì','Mercoledì','Giovedì','Venerdì','Sabato','Domenica'];
  const dayShort=['Lun','Mar','Mer','Gio','Ven','Sab','Dom'];
  const slots=[['mattina','MATTINA'],['pomeriggio','POMERIGGIO'],['sera','SERA']];

  let state = {
    startDate: isoLocal(new Date()),
    cycleDuration: 30,
    cycleUnit: 'days',
    selectedDate: isoLocal(new Date()),
    meds: [],
    taken: {},
    activeTab: 'week'
  };

  // Inizializzazione Firebase
  let db = null;
  const syncStatus = document.getElementById('syncStatus');

  if(firebaseConfig.apiKey !== "INSERISCI_QUI_API_KEY") {
    firebase.initializeApp(firebaseConfig);
    db = firebase.database();
    
    // Ascolta i cambiamenti nel Cloud
    db.ref('therapyData').on('value', (snapshot) => {
      const data = snapshot.val();
      if(data) {
        state = {...state, ...data};
        syncStatus.className = 'sync-status online';
        syncStatus.querySelector('span').textContent = 'Cloud Sincronizzato';
        render();
      }
    });
  } else {
    // Caricamento Locale se Firebase non è configurato
    const raw = localStorage.getItem(STORE_LOCAL);
    if(raw) state = JSON.parse(raw);
    state.selectedDate = isoLocal(new Date());
  }

  function save(){
    if(db) {
      db.ref('therapyData').set({
        startDate: state.startDate,
        cycleDuration: state.cycleDuration,
        cycleUnit: state.cycleUnit,
        meds: state.meds,
        taken: state.taken
      });
    }
    localStorage.setItem(STORE_LOCAL, JSON.stringify(state));
  }

  // Utility
  function med(name,dose,time,opts={}){ return {id:uid(),name,dose,time,days:opts.days||[0,1,2,3,4,5,6],startDate:opts.startDate||'',endDate:opts.endDate||'',note:opts.note||'',enabled:opts.enabled!==false}; }
  function uid(){return 'm'+Math.random().toString(36).slice(2,9)+Date.now().toString(36).slice(-4)}
  function pad(n){return String(n).padStart(2,'0')}
  function isoLocal(d){return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}`}
  function parseIso(s){const [y,m,d]=s.split('-').map(Number);return new Date(y,m-1,d)}
  function fmtShort(d){return `${d.getDate()} ${['gen','feb','mar','apr','mag','giu','lug','ago','set','ott','nov','dic'][d.getMonth()]}`}
  function fmtFull(d){return `${pad(d.getDate())}/${pad(d.getMonth()+1)}/${d.getFullYear()}`}
  function addDays(d,n){const x=new Date(d);x.setDate(x.getDate()+n);return x}
  function addDaysIso(iso,n){return isoLocal(addDays(parseIso(iso),n))}
  function diffDays(a,b){return Math.round((parseIso(a)-parseIso(b))/86400000)}
  function mondayOf(iso){const d=parseIso(iso);const day=(d.getDay()+6)%7;return addDays(d,-day)}
  function dayIndex(iso){return (parseIso(iso).getDay()+6)%7}

  const $=id=>document.getElementById(id);
  const startText=$('startText'),weekRange=$('weekRange'),daysEl=$('days'),dayTitle=$('dayTitle'),cycleText=$('cycleText'),sections=$('sections');
  const tabWeek=$('tabWeek'),tabMeds=$('tabMeds'),tabHistory=$('tabHistory');
  const weekPanel=$('weekPanel'),medsPanel=$('medsPanel'),historyPanel=$('historyPanel');
  const takenToday=$('takenToday'),takenWeek=$('takenWeek'),takenTodaySub=$('takenTodaySub'),takenWeekSub=$('takenWeekSub');
  const dueToday=$('dueToday'),weekPercent=$('weekPercent'),progressToday=$('progressToday'),progressWeek=$('progressWeek');

  tabWeek.onclick=()=>setTab('week');
  tabMeds.onclick=()=>setTab('meds');
  tabHistory.onclick=()=>setTab('history');
  
  $('prevWeek').onclick=()=>{state.selectedDate=isoLocal(addDays(parseIso(state.selectedDate),-7));render();};
  $('nextWeek').onclick=()=>{state.selectedDate=isoLocal(addDays(parseIso(state.selectedDate),7));render();};
  $('startDate').onchange=e=>{state.startDate=e.target.value||state.startDate; save(); render();};
  $('cycleDuration').onchange=e=>{state.cycleDuration=parseInt(e.target.value)||30; save(); render();};
  $('cycleUnit').onchange=e=>{state.cycleUnit=e.target.value; save(); render();};

  // Modale Aggiunta
  const mDaysContainer = $('mDays');
  let selectedModalDays = [0,1,2,3,4,5,6];
  dayShort.forEach((dn, i) => {
    const b = document.createElement('button'); b.className = 'daycheck on'; b.textContent = dn;
    b.onclick = () => { b.classList.toggle('on'); const idx = selectedModalDays.indexOf(i); if(idx > -1) selectedModalDays.splice(idx, 1); else selectedModalDays.push(i); selectedModalDays.sort(); };
    mDaysContainer.appendChild(b);
  });
  $('addMedBtn').onclick=()=>{ $('mStartDate').value = state.selectedDate; $('medModal').classList.add('active'); };
  $('mOp').onchange=e=>$('rampFields').style.display = (e.target.value === 'none' ? 'none' : 'flex');
  window.closeModal = () => $('medModal').classList.remove('active');
  document.querySelectorAll('.slot-checks .slot-check').forEach(btn => { btn.onclick = () => btn.classList.toggle('on'); });

  window.confirmMed = () => {
    const name = $('mName').value || 'Farmaco';
    const doseInitStr = $('mDoseInit').value || '1';
    const op = $('mOp').value;
    const startIso = $('mStartDate').value || state.selectedDate;
    const endIsoManual = $('mEndDate').value;
    const duration = parseInt($('mDur').value) || 30;
    const unit = $('mUnit').value;
    const selectedSlots = Array.from(document.querySelectorAll('.slot-checks .slot-check.on')).map(b => b.dataset.slot);
    if (selectedSlots.length === 0) { alert('Seleziona almeno un momento!'); return; }
    let totalDays;
    if(endIsoManual) totalDays = diffDays(endIsoManual, startIso) + 1;
    else { if(unit === 'weeks') totalDays = duration * 7; else if(unit === 'months') totalDays = duration * 30; else totalDays = duration; }
    const doseVal = parseFloat(doseInitStr.replace(/[^0-9.]/g, '')) || 0;
    const doseUnit = doseInitStr.replace(/[0-9.]/g, '').trim();
    if(op === 'none'){
      const perSlotDose = (doseVal / selectedSlots.length).toFixed(2);
      selectedSlots.forEach(slot => { state.meds.push(med(name, `${perSlotDose}${doseUnit}`, slot, { startDate: startIso, endDate: addDaysIso(startIso, totalDays - 1), days: [...selectedModalDays] })); });
    } else {
      const stepValTotal = parseFloat(($('mStep').value || '0').replace(/[^0-9.]/g, '')) || 0;
      const limitValTotal = $('mLimit').value !== '' ? parseFloat($('mLimit').value.replace(/[^0-9.]/g, '')) : null;
      const freq = parseInt($('mFreq').value) || 1;
      for (let d = 0; d < totalDays; d++) {
        const currentIso = addDaysIso(startIso, d);
        if(!selectedModalDays.includes(dayIndex(currentIso))) continue;
        const increments = Math.floor(d / freq);
        let dailyTotal = op === 'add' ? doseVal + (increments * stepValTotal) : doseVal - (increments * stepValTotal);
        if (limitValTotal !== null) { if (op === 'add' && dailyTotal > limitValTotal) dailyTotal = limitValTotal; if (op === 'sub' && dailyTotal < limitValTotal) dailyTotal = limitValTotal; }
        const perSlotDose = (dailyTotal / selectedSlots.length).toFixed(2);
        selectedSlots.forEach(slot => { state.meds.push(med(name, `${perSlotDose}${doseUnit}`, slot, { startDate: currentIso, endDate: currentIso, note: `Rampa Giorno ${d+1} (Tot: ${dailyTotal.toFixed(2)}${doseUnit})`, days: [dayIndex(currentIso)] })); });
      }
    }
    save(); render(); closeModal();
  };

  // Rimozione
  $('removeMedBtn').onclick=()=>{
    const list = $('removeList'); list.innerHTML = '';
    const uniqueMeds = [...new Set(state.meds.map(m => m.name))].sort();
    if(uniqueMeds.length === 0) list.innerHTML = '<div class="empty">Nessun farmaco presente.</div>';
    uniqueMeds.forEach(name => {
      const item = document.createElement('div'); item.className = 'modal-list-item';
      item.innerHTML = `<span>${name}</span> <button onclick="removeMedByName('${name.replace(/'/g, "\\'")}')">RIMUOVI TUTTI</button>`;
      list.appendChild(item);
    });
    $('removeModal').classList.add('active');
  };
  window.closeRemoveModal = () => $('removeModal').classList.remove('active');
  window.removeMedByName = (name) => { if(confirm(`Rimuovere tutte le voci per "${name}"?`)){ state.meds = state.meds.filter(m => m.name.toLowerCase() !== name.toLowerCase()); save(); render(); closeRemoveModal(); } };

  $('resetBtn').onclick=()=>{ if(confirm('Resettare tutto?')){ state.meds=[]; state.taken={}; save(); render(); } };
  $('exportBtn').onclick=()=>{const box=$('jsonBox'),wrap=$('jsonBoxWrap');wrap.classList.remove('hide');box.value=JSON.stringify(state,null,2);box.focus();box.select();};
  $('importBtn').onclick=()=>{const wrap=$('jsonBoxWrap'),box=$('jsonBox'); if(wrap.classList.contains('hide')){wrap.classList.remove('hide');return;} try{const d=JSON.parse(box.value); state.startDate=d.startDate; state.cycleDuration=d.cycleDuration; state.cycleUnit=d.cycleUnit; state.meds=d.meds; state.taken=d.taken; save(); render(); alert('Import OK');}catch(e){alert('Errore JSON');}};

  function setTab(t){state.activeTab=t;render();}
  function takenKey(date,id){return date+'|'+id}
  function isDue(m,date){ if(!m.enabled) return false; if(m.startDate && date<m.startDate) return false; if(m.endDate && date>m.endDate) return false; return (m.days||[]).includes(dayIndex(date)); }

  function render(){
    const endCycle = addDaysIso(state.startDate, (state.cycleUnit === 'weeks' ? state.cycleDuration * 7 : state.cycleDuration) - 1);
    startText.textContent=`Ciclo: ${fmtFull(parseIso(state.startDate))} — ${fmtFull(parseIso(endCycle))}`;
    $('startDate').value=state.startDate;
    $('cycleDuration').value=state.cycleDuration;
    $('cycleUnit').value=state.cycleUnit;
    tabWeek.classList.toggle('active',state.activeTab==='week');
    tabMeds.classList.toggle('active',state.activeTab==='meds');
    tabHistory.classList.toggle('active',state.activeTab==='history');
    weekPanel.classList.toggle('active',state.activeTab==='week');
    medsPanel.classList.toggle('active',state.activeTab==='meds');
    historyPanel.classList.toggle('active',state.activeTab==='history');
    if(state.activeTab==='week') renderWeek();
    if(state.activeTab==='meds') renderMeds();
    if(state.activeTab==='history') renderHistory();
  }

  function renderWeek(){
    const mon=mondayOf(state.selectedDate);
    const todayIso=isoLocal(new Date());
    weekRange.innerHTML=`${fmtShort(mon)} — ${fmtShort(addDays(mon,6))} ${todayIso>=isoLocal(mon)&&todayIso<=isoLocal(addDays(mon,6))?'<small>(corrente)</small>':''}`;
    daysEl.innerHTML='';
    for(let i=0;i<7;i++){
      const d=addDays(mon,i), iso=isoLocal(d);
      const b=document.createElement('button'); b.className='daychip'+(iso===state.selectedDate?' active':'')+(iso===todayIso?' today':'');
      b.innerHTML=`<span class="dn">${dayShort[i]}</span><span class="dd">${d.getDate()}</span>`;
      b.onclick=()=>{state.selectedDate=iso;renderWeek();};
      daysEl.appendChild(b);
    }
    dayTitle.innerHTML=`${dayNames[dayIndex(state.selectedDate)]} <span>${fmtFull(parseIso(state.selectedDate))}</span>`;
    const c=diffDays(state.selectedDate,state.startDate)+1;
    const totalDays = state.cycleUnit === 'weeks' ? state.cycleDuration * 7 : state.cycleDuration;
    cycleText.textContent = c > 0 && c <= totalDays ? `Giorno ciclo ${c} di ${totalDays}` : (c > totalDays ? 'Ciclo terminato' : 'Prima del ciclo');
    renderSummary(mon);
    sections.innerHTML='';
    slots.forEach(([slot,label])=>{
      const due=state.meds.filter(m=>m.time===slot && isDue(m,state.selectedDate));
      if(slot==='pomeriggio' && due.length===0) return;
      const wrap=document.createElement('section');wrap.className='section'; wrap.innerHTML=`<h3>${label}</h3>`;
      if(!due.length) wrap.innerHTML+='<div class="empty">Nessun farmaco.</div>';
      due.forEach(m=>wrap.appendChild(card(m)));
      sections.appendChild(wrap);
    });
  }

  function renderSummary(mon){
    const todayDue = state.meds.filter(m=>isDue(m,state.selectedDate));
    const todayTakenCount = todayDue.filter(m=>!!state.taken[takenKey(state.selectedDate,m.id)]).length;
    const weekDates = Array.from({length:7},(_,i)=>isoLocal(addDays(mon,i)));
    let weekDueCount=0, weekTakenCount=0;
    weekDates.forEach(date=>{ state.meds.forEach(m=>{ if(isDue(m,date)){ weekDueCount++; if(state.taken[takenKey(date,m.id)]) weekTakenCount++; } }); });
    const pToday = todayDue.length?Math.round(todayTakenCount/todayDue.length*100):0;
    const pWeek = weekDueCount?Math.round(weekTakenCount/weekDueCount*100):0;
    takenToday.textContent=`${todayTakenCount} / ${todayDue.length}`;
    takenWeek.textContent=`${weekTakenCount} / ${weekDueCount}`;
    dueToday.textContent=`${todayDue.length} voci`;
    weekPercent.textContent=`${pWeek}%`;
    progressToday.style.width=`${pToday}%`;
    progressWeek.style.width=`${pWeek}%`;
  }

  function card(m){
    const key=takenKey(state.selectedDate,m.id), done=!!state.taken[key];
    const div=document.createElement('div');div.className='card'+(done?' taken':'');
    div.innerHTML=`<button class="check">${done?'✓':''}</button><div class="txt"><div class="line1"><span class="name"></span><span class="dose"></span></div>${m.note?'<div class="note"></div>':''}</div>`;
    div.querySelector('.name').textContent=m.name; div.querySelector('.dose').textContent=m.dose;
    if(m.note) div.querySelector('.note').textContent=m.note;
    div.onclick=()=>{state.taken[key]=!state.taken[key]; if(!state.taken[key]) delete state.taken[key]; save(); renderWeek();};
    return div;
  }

  function renderMeds(){
    const box=$('medEditor'); box.innerHTML='';
    state.meds.forEach((m,idx)=>{
      const div=document.createElement('div');div.className='mededit';
      div.innerHTML=`
        <div class="medhead"><span class="handle">☰</span><div class="medtitle"></div><button class="mini" data-act="up">↑</button><button class="mini" data-act="down">↓</button><button class="mini" data-act="del">Elimina</button></div>
        <div class="grid2">
          <div class="field"><label>Nome</label><input data-k="name" value="${esc(m.name)}"></div>
          <div class="field"><label>Dose</label><input data-k="dose" value="${esc(m.dose)}"></div>
          <div class="field"><label>Momento</label><select data-k="time"><option value="mattina">Mattina</option><option value="pomeriggio">Pomeriggio</option><option value="sera">Sera</option></select></div>
          <div class="field"><label>Dal</label><input type="date" data-k="startDate" value="${esc(m.startDate)}"></div>
          <div class="field"><label>Al</label><input type="date" data-k="endDate" value="${esc(m.endDate)}"></div>
        </div>
        <div class="field" style="margin-top:10px"><label>Nota</label><input data-k="note" value="${esc(m.note)}"></div>
        <div class="field" style="margin-top:10px"><label>Giorni</label><div class="daysedit"></div></div>
      `;
      div.querySelector('.medtitle').textContent=m.name;
      div.querySelector('select[data-k="time"]').value=m.time;
      div.querySelectorAll('[data-k]').forEach(el=>{ el.onchange=()=>{ m[el.dataset.k]=el.value; save(); renderWeek(); }; });
      const de=div.querySelector('.daysedit');
      dayShort.forEach((dn,i)=>{
        const b=document.createElement('button'); b.className='daycheck'+((m.days||[]).includes(i)?' on':''); b.textContent=dn;
        b.onclick=()=>{const set=new Set(m.days||[]); set.has(i)?set.delete(i):set.add(i); m.days=[...set].sort(); save(); renderMeds(); renderWeek();};
        de.appendChild(b);
      });
      div.querySelector('[data-act="up"]').onclick=()=>{if(idx>0){[state.meds[idx],state.meds[idx-1]]=[state.meds[idx-1],state.meds[idx]];save();renderMeds();}};
      div.querySelector('[data-act="down"]').onclick=()=>{if(idx<state.meds.length-1){[state.meds[idx],state.meds[idx+1]]=[state.meds[idx+1],state.meds[idx]];save();renderMeds();}};
      div.querySelector('[data-act="del"]').onclick=()=>{if(confirm('Eliminare voce?')){state.meds.splice(idx,1);save();render();}};
      box.appendChild(div);
    });
  }

  function renderHistory(){
    const box = $('historyList'); box.innerHTML = '';
    const takenKeys = Object.keys(state.taken).sort().reverse();
    if(takenKeys.length === 0) box.innerHTML = '<div class="empty">Vuoto.</div>';
    takenKeys.forEach(key => {
      const [date, id] = key.split('|');
      const m = state.meds.find(item => item.id === id);
      if(m){
        const div = document.createElement('div'); div.className = 'history-item';
        div.innerHTML = `<div><div class="history-date">${fmtFull(parseIso(date))}</div><div class="history-details">${m.name} - ${m.dose} (${m.time})</div></div><button class="mini" style="color:var(--red)" onclick="removeHistory('${key}')">Elimina</button>`;
        box.appendChild(div);
      }
    });
  }

  window.removeHistory = (key) => { delete state.taken[key]; save(); render(); };
  function esc(s){return String(s||'').replaceAll('&','&amp;').replaceAll('"','&quot;').replaceAll('<','&lt;').replaceAll('>','&gt;')}
  render();
})();
</script>
</body>
</html>